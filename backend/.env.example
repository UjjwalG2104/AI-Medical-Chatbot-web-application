# ─── MongoDB ─────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
DB_NAME=medical_chatbot

# ─── OpenAI (optional — app falls back to rule-based if missing) ─
OPENAI_API_KEY=

# ─── Flask ───────────────────────────────────────────────────────
FLASK_PORT=5000
FLASK_DEBUG=true

# ─── Security/Auth ───────────────────────────────────────────────
JWT_SECRET_KEY=change-this-in-production

# ─── CORS (comma-separated domains or *) ─────────────────────────
CORS_ORIGINS=*
